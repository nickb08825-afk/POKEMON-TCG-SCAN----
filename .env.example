# Environment Variables
# Copy this file to .env and fill in your values

# --- Pokémon TCG API ---
# Get a free key at https://pokemontcg.io
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# SQLite is used by default in development (no URL needed).
# For production, set this to your PostgreSQL connection string.
DATABASE_URL=

# --- AI / Image Recognition (optional) ---
# Required only if using OpenAI Vision for card scanning
OPENAI_API_KEY=your_openai_api_key_here

# --- Frontend (Vite) ---
# Base URL of the backend API, used by the React app
VITE_API_BASE_URL=http://localhost:3000
